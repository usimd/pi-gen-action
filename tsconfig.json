{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["ES2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "types": ["node"],
    "outDir": "./lib",
    "rootDir": "./src",
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "useUnknownInCatchVariables": false,
    "verbatimModuleSyntax": false
    },
  "exclude": ["node_modules", "**/*.test.ts", "vitest.config.ts"]
}
